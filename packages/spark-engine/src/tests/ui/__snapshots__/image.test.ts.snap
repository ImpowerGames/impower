// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`image > animated (non-instant) show emits per-layer animate 1`] = `
[
  {
    "id": "req-1",
    "kind": "request",
    "method": "ui/update",
    "params": {
      "attributes": undefined,
      "breakpoints": {
        "lg": 1024,
        "md": 768,
        "sm": 640,
        "xl": 1280,
        "xs": 400,
      },
      "content": undefined,
      "element": "e-1",
      "style": {
        "display": null,
      },
    },
  },
  {
    "id": "req-2",
    "kind": "request",
    "method": "ui/write-image",
    "params": {
      "instant": false,
      "instructions": [
        {
          "content": {
            "background": "url("https://example.com/bg.png")",
            "enterAnimation": {
              "$name": "show",
              "$type": "animation",
              "keyframes": [
                {
                  "opacity": "1",
                },
              ],
              "target": {
                "$name": "self",
                "$type": "layer",
              },
              "timing": {
                "delay": "0s",
                "direction": "normal",
                "duration": 0,
                "easing": "linear",
                "fill": "both",
                "iterations": 1,
              },
            },
            "imageNames": "BG",
            "previousHideAnimation": {
              "$name": "hide",
              "$type": "animation",
              "keyframes": [
                {
                  "opacity": "0",
                },
              ],
              "target": {
                "$name": "self",
                "$type": "layer",
              },
              "timing": {
                "delay": "0s",
                "direction": "normal",
                "duration": 0,
                "easing": "linear",
                "fill": "both",
                "iterations": 1,
              },
            },
            "src": "https://example.com/bg.png",
          },
          "control": "show",
          "targetAnimations": [
            {
              "$name": "show",
              "$type": "animation",
              "keyframes": [
                {
                  "opacity": "1",
                },
              ],
              "target": {
                "$name": "self",
                "$type": "layer",
              },
              "timing": {
                "delay": "0s",
                "direction": "normal",
                "duration": "0s",
                "easing": "linear",
                "fill": "both",
                "iterations": 1,
              },
            },
          ],
        },
      ],
      "target": "backdrop",
    },
  },
]
`;

