    "params": {
      "instant": true,
      "instructions": [
        {
          "content": {
            "background": "url("https://example.com/hero.png")",
            "enterAnimation": {
              "$name": "show",
              "$type": "animation",
              "keyframes": [
                {
                  "opacity": "1",
                },
              ],
              "target": {
                "$name": "self",
                "$type": "layer",
              },
              "timing": {
                "delay": "0s",
                "direction": "normal",
                "duration": "0s",
                "easing": "linear",
                "fill": "both",
                "iterations": 1,
              },
            },
            "imageNames": "SPRITE",
            "previousHideAnimation": {
              "$name": "hide",
              "$type": "animation",
              "keyframes": [
                {
                  "opacity": "0",
                },
              ],
              "target": {
                "$name": "self",
                "$type": "layer",
              },
              "timing": {
                "delay": "0s",
                "direction": "normal",
                "duration": "0s",
                "easing": "linear",
                "fill": "both",
                "iterations": 1,
              },
            },
            "src": "https://example.com/hero.png",
          },
          "control": "show",
          "targetAnimations": [
            {
              "$name": "show",
              "$type": "animation",
              "keyframes": [
                {
                  "opacity": "1",
                },
              ],
              "target": {
                "$name": "self",
                "$type": "layer",
              },
              "timing": {
                "delay": "0s",
                "direction": "normal",
                "duration": "0s",
                "easing": "linear",
                "fill": "both",
                "iterations": 1,
              },
            },
          ],
        },
        {
          "control": "animate",
          "targetAnimations": [
            {
              "$name": "shake",
              "$type": "animation",
              "keyframes": [
                {
                  "transform": "translate(0.4vh, 0.2vh)",
                },
                {
                  "transform": "translate(-0.2vh, -0.4vh)",
                },
                {
                  "transform": "translate(-0.6vh, 0vh)",
                },
                {
                  "transform": "translate(0vh, 0.4vh)",
                },
                {
                  "transform": "translate(0.2vh, -0.2vh)",
                },
                {
                  "transform": "translate(-0.2vh, 0.4vh)",
                },
                {
                  "transform": "translate(-0.6vh, 0.2vh)",
                },
                {
                  "transform": "translate(0.4vh, 0.2vh)",
                },
                {
                  "transform": "translate(-0.2vh, -0.2vh)",
                },
                {
                  "transform": "translate(0.4vh, 0.4vh)",
                },
                {
                  "transform": "translate(0.2vh, -0.4vh)",
                },
              ],
              "target": {
                "$name": "self",
                "$type": "layer",
              },
              "timing": {
                "delay": "0s",
                "direction": "normal",
                "duration": "0s",
                "easing": "ease-in-out",
                "fill": "none",
                "iterations": 1,
              },
            },
          ],
        },
      ],
      "target": "portrait",
    },
  },
]
`;

