{
  "name": "@impower/spark-web-player",
  "displayName": "Spark Web Player",
  "description": "Web component that allows users to play spark games.",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "node ./scripts/bundle-globals.ts",
    "watch": "node ./scripts/bundle-globals.ts --watch",
    "package": "node ./scripts/bundle-globals.ts --production",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@impower/impower-ui": "file:../impower-ui",
    "@impower/spark-dom": "file:../spark-dom",
    "@impower/spark-editor-protocol": "file:../spark-editor-protocol",
    "@impower/spark-engine": "file:../spark-engine",
    "@impower/sparkdown": "file:../sparkdown",
    "@impower/jsonrpc": "file:../jsonrpc",
    "gl-matrix": "^3.4.3",
    "pixi.js": "^8.9.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "chokidar": "^4.0.3",
    "dts-bundle-generator": "^9.5.1",
    "jsdom": "^25.0.1",
    "ts-morph": "^25.0.1",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "preact": "^10.29.1",
    "preact-custom-element": "^4.6.0"
  }
}
