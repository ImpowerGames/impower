  --theme-ease-bounce: linear(0,0.004,0.016,0.035,0.063,0.098,0.141 13.6%,0.25,0.391,0.563,0.765,1,0.891 40.9%,0.848,0.813,0.785,0.766,0.754,0.75,0.754,0.766,0.785,0.813,0.848,0.891 68.2%,1 72.7%,0.973,0.953,0.941,0.938,0.941,0.953,0.973,1,0.988,0.984,0.988,1);
  --theme-ease-in_sine: cubic-bezier(0.12,0,0.39,0);
  --theme-ease-out_sine: cubic-bezier(0.61,1,0.88,1);
  --theme-ease-in_out_sine: cubic-bezier(0.37,0,0.63,1);
  --theme-ease-in_quad: cubic-bezier(0.11,0,0.5,0);
  --theme-ease-out_quad: cubic-bezier(0.5,1,0.89,1);
  --theme-ease-in_out_quad: cubic-bezier(0.45,0,0.55,1);
  --theme-ease-in_cubic: cubic-bezier(0.32,0,0.67,0);
  --theme-ease-out_cubic: cubic-bezier(0.33,1,0.68,1);
  --theme-ease-in_out_cubic: cubic-bezier(0.65,0,0.35,1);
  --theme-ease-in_quart: cubic-bezier(0.5,0,0.75,0);
  --theme-ease-out_quart: cubic-bezier(0.25,1,0.5,1);
  --theme-ease-in_out_quart: cubic-bezier(0.76,0,0.24,1);
  --theme-ease-in_quint: cubic-bezier(0.64,0,0.78,0);
  --theme-ease-out_quint: cubic-bezier(0.22,1,0.36,1);
  --theme-ease-in_out_quint: cubic-bezier(0.83,0,0.17,1);
  --theme-ease-in_expo: cubic-bezier(0.7,0,0.84,0);
  --theme-ease-out_expo: cubic-bezier(0.16,1,0.3,1);
  --theme-ease-in_out_expo: cubic-bezier(0.87,0,0.13,1);
