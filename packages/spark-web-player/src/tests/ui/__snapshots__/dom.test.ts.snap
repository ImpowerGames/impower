            },
            {
              "class": "style-animations",
              "style": "display: none;",
              "tag": "style",
              "text": "@keyframes show {
  to { opacity: 1; }
}
@keyframes hide {
  to { opacity: 0; }
}
@keyframes align_left {
  to { translate: calc(0 * (100cqw - 100%)) 0px; }
}
@keyframes align_center {
  to { translate: calc(0.5 * (100cqw - 100%)) 0px; }
}
@keyframes align_right {
  to { translate: calc(1 * (100cqw - 100%)) 0px; }
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
@keyframes ping {
  0% { offset: 0.75; transform: scale(2); opacity: 0; }
  100% { offset: 1; transform: scale(2); opacity: 0; }
}
@keyframes bounce {
  0% { transform: translateY(-50%); animation-timing-function: cubic-bezier(0.8,0,1,1); }
  50% { transform: none; animation-timing-function: cubic-bezier(0,0,0.2,1); }
  100% { transform: translateY(-50%); animation-timing-function: cubic-bezier(0.8,0,1,1); }
}
@keyframes wave {
  0% { transform: translateY(0); }
  50% { transform: translateY(-15%); }
  100% { transform: translateY(0); }
}
@keyframes wavy {
  0% { transform: translateY(0); }
  50% { transform: translateY(-15%); }
  100% { transform: translateY(0); }
}
@keyframes shaky {
  0% { left: calc(1em / 60); top: calc(1em / 60); }
  10% { left: calc(-1em / 60); top: calc(-2em / 60); }
  20% { left: calc(-2em / 60); top: calc(0em / 60); }
  30% { left: calc(2em / 60); top: calc(2em / 60); }
  40% { left: calc(1em / 60); top: calc(-1em / 60); }
  50% { left: calc(-1em / 60); top: calc(2em / 60); }
  60% { left: calc(-2em / 60); top: calc(1em / 60); }
  70% { left: calc(2em / 60); top: calc(1em / 60); }
  80% { left: calc(-1em / 60); top: calc(-1em / 60); }
  90% { left: calc(1em / 60); top: calc(2em / 60); }
  100% { left: calc(1em / 60); top: calc(-2em / 60); }
}
@keyframes shake {
  0% { transform: translate(0.4vh, 0.2vh); }
  10% { transform: translate(-0.2vh, -0.4vh); }
  20% { transform: translate(-0.6vh, 0vh); }
  30% { transform: translate(0vh, 0.4vh); }
  40% { transform: translate(0.2vh, -0.2vh); }
  50% { transform: translate(-0.2vh, 0.4vh); }
  60% { transform: translate(-0.6vh, 0.2vh); }
  70% { transform: translate(0.4vh, 0.2vh); }
  80% { transform: translate(-0.2vh, -0.2vh); }
  90% { transform: translate(0.4vh, 0.4vh); }
  100% { transform: translate(0.2vh, -0.4vh); }
}
@keyframes shaking {
  0% { transform: translate(0.4vh, 0.2vh); }
  10% { transform: translate(-0.2vh, -0.4vh); }
  20% { transform: translate(-0.6vh, 0vh); }
  30% { transform: translate(0vh, 0.4vh); }
  40% { transform: translate(0.2vh, -0.2vh); }
  50% { transform: translate(-0.2vh, 0.4vh); }
  60% { transform: translate(-0.6vh, 0.2vh); }
  70% { transform: translate(0.4vh, 0.2vh); }
  80% { transform: translate(-0.2vh, -0.2vh); }
  90% { transform: translate(0.4vh, 0.4vh); }
  100% { transform: translate(0.2vh, -0.4vh); }
}
@keyframes shiver {
  0% { transform: translate(0.2vh, 0.1vh); }
  10% { transform: translate(-0.1vh, -0.2vh); }
  20% { transform: translate(-0.3vh, 0vh); }
  30% { transform: translate(0vh, 0.2vh); }
  40% { transform: translate(0.1vh, -0.1vh); }
  50% { transform: translate(-0.1vh, 0.2vh); }
  60% { transform: translate(-0.3vh, 0.1vh); }
  70% { transform: translate(0.2vh, 0.1vh); }
  80% { transform: translate(-0.1vh, -0.1vh); }
  90% { transform: translate(0.2vh, 0.2vh); }
  100% { transform: translate(0.1vh, -0.2vh); }
}
@keyframes shivering {
  0% { transform: translate(0.2vh, 0.1vh); }
  10% { transform: translate(-0.1vh, -0.2vh); }
  20% { transform: translate(-0.3vh, 0vh); }
  30% { transform: translate(0vh, 0.2vh); }
  40% { transform: translate(0.1vh, -0.1vh); }
  50% { transform: translate(-0.1vh, 0.2vh); }
  60% { transform: translate(-0.3vh, 0.1vh); }
  70% { transform: translate(0.2vh, 0.1vh); }
  80% { transform: translate(-0.1vh, -0.1vh); }
  90% { transform: translate(0.2vh, 0.2vh); }
  100% { transform: translate(0.1vh, -0.2vh); }
}
@keyframes waitout {
  to { opacity: 0; }
}
@keyframes waitin {
  to { opacity: 1; }
}
@keyframes fadeout {
  to { opacity: 0; }
}
@keyframes fadein {
  to { opacity: 1; }
}
@keyframes pulse {
  0% { opacity: 0; }
  50% { opacity: 1; }
  100% { opacity: 0; }
}
@keyframes blackout {
  0% { background-color: black; opacity: 0; }
  100% { background-color: black; opacity: 1; }
}
@keyframes blackin {
  0% { background-color: black; opacity: 1; }
  100% { background-color: black; opacity: 0; }
}
@keyframes blackpulse {
  0% { background-color: black; opacity: 0; }
  50% { background-color: black; opacity: 1; }
  100% { background-color: black; opacity: 0; }
}
@keyframes whiteout {
  0% { background-color: white; opacity: 0; }
  100% { background-color: white; opacity: 1; }
}
@keyframes whitein {
  0% { background-color: white; opacity: 1; }
  100% { background-color: white; opacity: 0; }
}
@keyframes whitepulse {
  0% { background-color: white; opacity: 0; }
  50% { background-color: white; opacity: 1; }
  100% { background-color: white; opacity: 0; }
}",
            },
            {
              "class": "style-styles",
              "style": "display: none;",
              "tag": "style",
              "text": ":host #game .main {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
    Helvetica, Arial, system-ui, sans-serif, "Apple Color Emoji",
    "Segoe UI Emoji", "Segoe UI Symbol";
  font-size: 1.25rem;
  line-height: 1.5;
  color: white;
  @container screen (max-width:640px) {
    font-size: 1.125rem;
  }
}
:host #game .row {
  display: flex;
  flex-direction: row;
}
:host #game .column {
  display: flex;
  flex-direction: column;
}
:host #game .stack {
  >* {
    position: absolute;
    inset: 0px;
  }
}
:host #game .overlay {
  position: absolute;
  inset: 0px;
}
:host #game .text {
  display: block;
  pointer-events: auto;
  user-select: none;
  text-wrap: wrap;
  white-space: pre-line;
  * {
    display: inline;
  }
}
:host #game .stroke {
  display: block;
  pointer-events: none;
  cursor: default;
  user-select: none;
  text-wrap: wrap;
  position: absolute;
  inset: 0px;
  text-shadow: 1px 0px 0 black,0.6234898018587336px 0.7818314824680298px 0 black,-0.22252093395631434px 0.9749279121818236px 0 black,-0.900968867902419px 0.43388373911755823px 0 black,-0.9009688679024191px -0.433883739117558px 0 black,-0.2225209339563146px -0.9749279121818236px 0 black,0.6234898018587334px -0.7818314824680299px 0 black;
  color: black;
  white-space: pre-line;
  * {
    display: inline;
  }
}
:host #game .text_line {
  display: block;
  text-wrap: wrap;
}
:host #game .text_word {
  display: inline-block;
}
:host #game .text_space {
  display: inline;
}
:host #game .image {
  display: block;
  pointer-events: auto;
  position: absolute;
  inset: 0px;
  isolation: isolate;
  will-change: transform;
  container-type: size;
  container-name: image;
  >* {
    position: absolute;
    inset: 0px;
    background-position: center;
    background-repeat: no-repeat;
    background-size: auto 100%;
    will-change: transform;
    min-width: 100%;
    width: var(--theme-size-fit-content);
    translate: calc(0.5 * (100cqw - 100%)) 0px;
  }
}
:host #game .object {
  height: 100%;
  object-fit: cover;
  visibility: hidden;
}
:host #game .mask {
  display: block;
  pointer-events: auto;
  position: absolute;
  inset: 0px;
  isolation: isolate;
  will-change: transform;
  >* {
    mix-blend-mode: plus-lighter;
    position: absolute;
    inset: 0px;
    mask-position: center;
    mask-repeat: no-repeat;
    mask-size: auto 100%;
    will-change: transform;
  }
}
:host #game .loading_bar {
  z-index: 1000;
  position: relative;
  width: 100%;
  height: 4px;
}
:host #game .loading_fill {
  width: 100%;
  height: 100%;
  background-color: var(--theme-color-cyan50);
  transform: scaleX(var(--loading_progress));
  transform-origin: left;
}
:host #game .screen {
  position: absolute;
  inset: 0px;
  pointer-events: none;
  cursor: default;
  * {
    pointer-events: none;
    cursor: default;
  }
}
:host #game .stage {
  position: absolute;
  inset: 0px;
  display: flex;
  flex-direction: column;
}
:host #game .backdrop {
  position: absolute;
  inset: 0px;
  background-position: center;
  background-size: cover;
}
:host #game .portrait {
  position: absolute;
  top: 10%;
  right: 0px;
  bottom: 0px;
  left: 0px;
  display: flex;
  flex-direction: column;
  background-size: auto 100%;
  background-position: center;
  >.image * {
    mix-blend-mode: plus-lighter;
  }
}
:host #game .choices {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  gap: 8px;
  margin-bottom: 100px;
  @container screen (max-width:640px) {
    margin-bottom: 120px;
  }
}
:host #game .choice {
  display: flex;
  flex-direction: row;
  width: 90%;
  max-width: 800px;
  background-color: rgb(0 0 0 / 65%);
  padding: 8px;
  border-radius: 8px;
  border: 1px solid;
  text-align: center;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  &:hover {
    background-color: black;
    transition: all 0.15s linear;
  }
}
:host #game .button {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 8px 20px;
  border-radius: 8px;
  border: 1px solid rgb(95 95 95);
  background-color: rgb(52 52 52);
  color: white;
  font-weight: 600;
  cursor: pointer;
  transition: background-color 0.15s linear;
  &:hover {
    background-color: rgb(69 69 69);
  }
}
:host #game .field {
  padding: 8px 12px;
  border-radius: 6px;
  border: 1px solid rgb(95 95 95);
  background-color: rgb(37 37 37);
  color: white;
}
:host #game .checkbox {
  width: 20px;
  height: 20px;
  cursor: pointer;
  accent-color: rgb(96 165 250);
}
:host #game .slider {
  width: 200px;
  cursor: pointer;
  accent-color: rgb(96 165 250);
}
:host #game .textbox {
  position: absolute;
  bottom: 0px;
  left: 0px;
  right: 0px;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: white;
  flex: 1;
}
:host #game .textbox_background {
  position: absolute;
  inset: 0px;
  background-image: linear-gradient(to bottom, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.5) 25%, rgba(0, 0, 0, 1) 100%);
}
:host #game .textbox_content {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  max-width: 800px;
  width: 100%;
  margin: 0px auto;
  min-height: 200px;
  padding: 16px 32px;
  @container screen (max-width:640px) {
    min-height: 240px;
    padding: 16px;
  }
}
:host #game .character_info {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: flex-end;
  gap: 8px;
  line-height: 1;
  font-size: 1.875rem;
  @container screen (max-width:640px) {
    font-size: 1.5rem;
  }
}
:host #game .character_name {
  padding-bottom: 8px;
  font-weight: 600px;
}
:host #game .character_parenthetical {
  padding-bottom: 8px;
  font-weight: 400px;
  font-size: 1rem;
  @container screen (max-width:640px) {
    font-size: 0.875rem;
  }
}
:host #game .title {
  position: absolute;
  inset: 0px;
  padding-left: 40px;
  padding-right: 40px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-self: center;
  text-align: center;
  font-weight: 700;
}
:host #game .heading {
  position: absolute;
  inset: 0px;
  padding-left: 40px;
  padding-right: 40px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-self: center;
  text-align: center;
  font-weight: 700;
}
:host #game .transitional {
  position: absolute;
  inset: 0px;
  padding-left: 40px;
  padding-right: 40px;
  padding-bottom: 24px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-self: flex-end;
  text-align: right;
  width: 100%;
}
:host #game .dialogue {
  margin: 0px auto;
  width: 68%;
  @container screen (max-width:640px) {
    width: 80%;
  }
}
:host #game .action {
  position: absolute;
  inset: 0px;
  padding-left: 40px;
  padding-right: 40px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-self: center;
  text-align: center;
}
:host #game .continue_indicator {
  opacity: 0;
  line-height: 1;
  width: 16px;
  height: 16px;
  position: absolute;
  right: 16px;
  bottom: 16px;
  font-size: 16px;
  transition: opacity 0.25s linear;
  animation: var(--theme-animation-0.5s), var(--theme-animation-infinite), var(--theme-animation-bounce);
  animation-play-state: paused;
