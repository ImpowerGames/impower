  parameters = { "0", "0.009", "0.035 2.1%", "0.141", "0.281 6.7%", "0.723 12.9%", "0.938 16.7%", "1.017", "1.077", "1.121", "1.149 24.3%", "1.159", "1.163", "1.161", "1.154 29.9%", "1.129 32.8%", "1.051 39.6%", "1.017 43.1%", "0.991", "0.977 51%", "0.974 53.8%", "0.975 57.1%", "0.997 69.8%", "1.003 76.9%", "1.004 83.8%", "1" }
end

define elastic as ease with
  ["function"] = "linear"
  parameters = { "0", "0.218 2.1%", "0.862 6.5%", "1.114", "1.296 10.7%", "1.346", "1.37 12.9%", "1.373", "1.364 14.5%", "1.315 16.2%", "1.032 21.8%", "0.941 24%", "0.891 25.9%", "0.877", "0.869 27.8%", "0.87", "0.882 30.7%", "0.907 32.4%", "0.981 36.4%", "1.012 38.3%", "1.036", "1.046 42.7% 44.1%", "1.042 45.7%", "0.996 53.3%", "0.988", "0.984 57.5%", "0.985 60.7%", "1.001 68.1%", "1.006 72.2%", "0.998 86.7%", "1" }
end

define bounce as ease with
  ["function"] = "linear"
  parameters = { "0", "0.004", "0.016", "0.035", "0.063", "0.098", "0.141 13.6%", "0.25", "0.391", "0.563", "0.765", "1", "0.891 40.9%", "0.848", "0.813", "0.785", "0.766", "0.754", "0.75", "0.754", "0.766", "0.785", "0.813", "0.848", "0.891 68.2%", "1 72.7%", "0.973", "0.953", "0.941", "0.938", "0.941", "0.953", "0.973", "1", "0.988", "0.984", "0.988", "1" }
