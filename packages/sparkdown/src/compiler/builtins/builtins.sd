define component with
  ["$recursive"] = true
end

define theme with
  ["$recursive"] = true
end

define style with
  ["$recursive"] = true
end

style main with
  font_family = "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto,\n    Helvetica, Arial, system-ui, sans-serif, \"Apple Color Emoji\",\n    \"Segoe UI Emoji\", \"Segoe UI Symbol\""
  font_size = 1.25rem
  line_height = 1.5
  color = white
  @screen_size(sm):
    font_size = 1.125rem
end

style row with
  display = flex
  flex_direction = row
end

style column with
  display = flex
  flex_direction = column
end

style stack with
  > *:
    position = absolute
    inset = 0
end

style overlay with
  position = absolute
  inset = 0
end

style text with
  display = block
  pointer_events = auto
  user_select = none
  text_wrap = wrap
  white_space = pre-line
  >> *:
    display = inline
end

style stroke with
  display = block
  pointer_events = none
  user_select = none
  text_wrap = wrap
  position = absolute
  inset = 0
  text_stroke = 1
  color = black
  white_space = pre-line
  >> *:
    display = inline
end

style text_line with
  display = block
  text_wrap = wrap
end

style text_word with
  display = inline-block
end

style text_space with
  display = inline
end

style text_letter with
end

style image with
  display = block
  pointer_events = auto
  position = absolute
  inset = 0
  isolation = isolate
  will_change = transform
  container_type = size
  container_name = image
  > *:
    position = absolute
    inset = 0
    background_position = center
    background_repeat = no-repeat
    background_size = auto 100%
    will_change = transform
    min_width = 100%
    width = fit-content
    translate = calc(0.5 * (100cqw - 100%)) 0
end

style object with
  height = 100%
  object_fit = cover
  visibility = hidden
end

style mask with
  display = block
  pointer_events = auto
  position = absolute
  inset = 0
  isolation = isolate
  will_change = transform
  > *:
    mix_blend_mode = plus-lighter
    position = absolute
    inset = 0
    mask_position = center
    mask_repeat = no-repeat
    mask_size = auto 100%
    will_change = transform
end

style loading_bar with
  z_index = 1000
  position = relative
  width = 100%
  height = 4px
end

style loading_fill with
  width = 100%
  height = 100%
  background_color = cyan50
  transform = scaleX(var(--loading_progress))
  transform_origin = left
end

style screen with
  position = absolute
  inset = 0
  pointer_events = none
  >> *:
    pointer_events = none
end

style stage with
  position = absolute
  inset = 0
  display = flex
  flex_direction = column
end

style backdrop with
  position = absolute
  inset = 0
  background_position = center
  background_size = cover
end

style portrait with
  position = absolute
  top = 10%
  right = 0
  bottom = 0
  left = 0
  display = flex
  flex_direction = column
  background_size = auto 100%
  background_position = center
  > image >> *:
    mix_blend_mode = plus-lighter
end

style choices with
  position = relative
  flex = 1
  display = flex
  flex_direction = column
  align_items = center
  justify_content = center
  width = 100%
  gap = 8px
  margin_bottom = 100px
  @screen_size(sm):
    margin_bottom = 120px
end

style choice with
  display = flex
  flex_direction = row
  width = 90%
  max_width = 800px
  background_color = rgb(0 0 0 / 65%)
  padding = 8px
  border_radius = 8px
  border = 1px solid
  text_align = center
  align_items = center
  justify_content = center
  cursor = pointer
  @hovered:
    background_color = black
    transition = all 0.15s linear
end

style button with
  display = flex
  flex_direction = row
  align_items = center
  justify_content = center
  text_align = center
  padding = 8px 20px
  border_radius = 8px
  border = 1px solid rgb(95 95 95)
  background_color = rgb(52 52 52)
  color = white
  font_weight = 600
  cursor = pointer
  transition = background-color 0.15s linear
  @hovered:
    background_color = rgb(69 69 69)
end

style field with
  padding = 8px 12px
  border_radius = 6px
  border = 1px solid rgb(95 95 95)
  background_color = rgb(37 37 37)
  color = white
end

style checkbox with
  width = 20px
  height = 20px
  cursor = pointer
  accent_color = rgb(96 165 250)
end

style slider with
  width = 200px
  cursor = pointer
  accent_color = rgb(96 165 250)
end

style link with
  color = rgb(96 165 250)
  text_decoration = underline
  cursor = pointer
end

style dropdown with
  padding = 8px 12px
  border_radius = 6px
  border = 1px solid rgb(95 95 95)
  background_color = rgb(37 37 37)
  color = white
  cursor = pointer
end

style option with
  background_color = rgb(37 37 37)
  color = white
end

style textbox with
  position = absolute
  bottom = 0
  left = 0
  right = 0
  display = flex
  flex_direction = column
  align_items = center
  color = white
  flex = 1
end

style textbox_background with
  position = absolute
  inset = 0
  background_image = linear-gradient(to bottom, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.5) 25%, rgba(0, 0, 0, 1) 100%)
end

style textbox_content with
  position = relative
  flex = 1
  display = flex
  flex_direction = column
  max_width = 800px
  width = 100%
  margin = 0 auto
  min_height = 200px
  padding = 16px 32px
  @screen_size(sm):
    min_height = 240px
    padding = 16px
end

style character_info with
  display = flex
  flex_direction = row
  justify_content = center
  align_items = flex-end
  gap = 8px
  line_height = 1
  font_size = 1.875rem
  @screen_size(sm):
    font_size = 1.5rem
end

style character_name with
  padding_bottom = 8px
  font_weight = 600px
end

style character_parenthetical with
  padding_bottom = 8px
  font_weight = 400px
  font_size = 1rem
  @screen_size(sm):
    font_size = 0.875rem
end

style title with
  position = absolute
  inset = 0
  padding_left = 40px
  padding_right = 40px
  display = flex
  flex_direction = column
  justify_content = center
  align_self = center
  text_align = center
  font_weight = bold
end

style heading with
  position = absolute
  inset = 0
  padding_left = 40px
  padding_right = 40px
  display = flex
  flex_direction = column
  justify_content = center
  align_self = center
  text_align = center
  font_weight = bold
end

style transitional with
  position = absolute
  inset = 0
  padding_left = 40px
  padding_right = 40px
  padding_bottom = 24px
  display = flex
  flex_direction = column
  justify_content = center
  align_self = flex-end
  text_align = right
  width = 100%
end

style dialogue with
  margin = 0 auto
  width = 68%
  @screen_size(sm):
    width = 80%
end

style action with
  position = absolute
  inset = 0
  padding_left = 40px
  padding_right = 40px
  display = flex
  flex_direction = column
  justify_content = center
  align_self = center
  text_align = center
end

style continue_indicator with
  opacity = 0
  line_height = 1
  width = 16px
  height = 16px
  position = absolute
  right = 16px
  bottom = 16px
  font_size = 16px
  transition = opacity 0.25s linear
  animation = 0.5s infinite bounce
  animation_play_state = paused
end

define screen with
  ["$recursive"] = true
end

screen loading with
  loading_bar:
    loading_fill:
end

screen main with
  stage:
    animation:
    backdrop:
      image = transparent
    portrait:
      image:
  choices:
    choice 0:
      text:
    choice 1:
      text:
    choice 2:
      text:
    choice 3:
      text:
    choice 4:
      text:
    choice 5:
      text:
  textbox:
    textbox_background:
    textbox_content:
      character_info:
        character_name:
          stroke:
          text:
        character_parenthetical:
          stroke:
          text:
      title:
        stroke:
        text:
      heading:
        stroke:
        text:
      transitional:
        stroke:
        text:
      dialogue:
        stroke:
        text:
      action:
        stroke:
        text:
    continue_indicator:
      text = ▼
  screen:
    animation:
end

define layer with
end

define self as layer with
end

define instance as layer with
end

define object as layer with
end

define animation with
  target = layer.self
  keyframes = {}
  timing = { delay = 0, duration = 0, easing = "ease", iterations = 1, fill = "both", direction = "normal" }
end

animation show with
  target = layer.self
  keyframes:
    -
      opacity = "1"
  timing:
    delay = 0
    duration = 0
    easing = "linear"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation hide with
  target = layer.self
  keyframes:
    -
      opacity = "0"
  timing:
    delay = 0
    duration = 0
    easing = "linear"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation align_left with
  target = layer.instance
  keyframes:
    -
      translate = "calc(0 * (100cqw - 100%)) 0"
  timing:
    delay = 0
    duration = 0
    easing = "ease-in-out"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation align_center with
  target = layer.instance
  keyframes:
    -
      translate = "calc(0.5 * (100cqw - 100%)) 0"
  timing:
    delay = 0
    duration = 0
    easing = "ease-in-out"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation align_right with
  target = layer.instance
  keyframes:
    -
      translate = "calc(1 * (100cqw - 100%)) 0"
  timing:
    delay = 0
    duration = 0
    easing = "ease-in-out"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation spin with
  target = layer.self
  keyframes:
    -
      transform = "rotate(360deg)"
  timing:
    delay = 0
    duration = 0
    easing = "linear"
    iterations = "infinite"
    fill = "none"
    direction = "normal"
end

animation ping with
  target = layer.self
  keyframes:
    -
      offset = 0.75
      transform = "scale(2)"
      opacity = "0"
    -
      offset = 1
      transform = "scale(2)"
      opacity = "0"
  timing:
    delay = 0
    duration = 0
    easing = "ease"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation bounce with
  target = layer.self
  keyframes:
    -
      transform = "translateY(-50%)"
      easing = "cubic-bezier(0.8,0,1,1)"
    -
      transform = "none"
      easing = "cubic-bezier(0,0,0.2,1)"
    -
      transform = "translateY(-50%)"
      easing = "cubic-bezier(0.8,0,1,1)"
  timing:
    delay = 0
    duration = 0
    easing = "ease"
    iterations = "infinite"
    fill = "none"
    direction = "normal"
end

animation wave with
  target = layer.self
  keyframes:
    -
      transform = "translateY(0)"
    -
      transform = "translateY(-15%)"
    -
      transform = "translateY(0)"
  timing:
    delay = 0
    duration = "750ms"
    easing = "ease-in-out"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation wavy with
  target = layer.self
  keyframes:
    -
      transform = "translateY(0)"
    -
      transform = "translateY(-15%)"
    -
      transform = "translateY(0)"
  timing:
    delay = 0
    duration = "750ms"
    easing = "ease-in-out"
    iterations = "infinite"
    fill = "none"
    direction = "normal"
end

animation shaky with
  target = layer.self
  keyframes:
    -
      left = "calc(1em / 60)"
      top = "calc(1em / 60)"
    -
      left = "calc(-1em / 60)"
      top = "calc(-2em / 60)"
    -
      left = "calc(-2em / 60)"
      top = "calc(0em / 60)"
    -
      left = "calc(2em / 60)"
      top = "calc(2em / 60)"
    -
      left = "calc(1em / 60)"
      top = "calc(-1em / 60)"
    -
      left = "calc(-1em / 60)"
      top = "calc(2em / 60)"
    -
      left = "calc(-2em / 60)"
      top = "calc(1em / 60)"
    -
      left = "calc(2em / 60)"
      top = "calc(1em / 60)"
    -
      left = "calc(-1em / 60)"
      top = "calc(-1em / 60)"
    -
      left = "calc(1em / 60)"
      top = "calc(2em / 60)"
    -
      left = "calc(1em / 60)"
      top = "calc(-2em / 60)"
  timing:
    delay = 0
    duration = "300ms"
    easing = "ease-in-out"
    iterations = "infinite"
    fill = "none"
    direction = "normal"
end

animation shake with
  target = layer.self
  keyframes:
    -
      transform = "translate(0.4vh, 0.2vh)"
    -
      transform = "translate(-0.2vh, -0.4vh)"
    -
      transform = "translate(-0.6vh, 0vh)"
    -
      transform = "translate(0vh, 0.4vh)"
    -
      transform = "translate(0.2vh, -0.2vh)"
    -
      transform = "translate(-0.2vh, 0.4vh)"
    -
      transform = "translate(-0.6vh, 0.2vh)"
    -
      transform = "translate(0.4vh, 0.2vh)"
    -
      transform = "translate(-0.2vh, -0.2vh)"
    -
      transform = "translate(0.4vh, 0.4vh)"
    -
      transform = "translate(0.2vh, -0.4vh)"
  timing:
    delay = 0
    duration = "300ms"
    easing = "ease-in-out"
    iterations = 1
    fill = "none"
    direction = "normal"
end

animation shaking with
  target = layer.self
  keyframes:
    -
      transform = "translate(0.4vh, 0.2vh)"
    -
      transform = "translate(-0.2vh, -0.4vh)"
    -
      transform = "translate(-0.6vh, 0vh)"
    -
      transform = "translate(0vh, 0.4vh)"
    -
      transform = "translate(0.2vh, -0.2vh)"
    -
      transform = "translate(-0.2vh, 0.4vh)"
    -
      transform = "translate(-0.6vh, 0.2vh)"
    -
      transform = "translate(0.4vh, 0.2vh)"
    -
      transform = "translate(-0.2vh, -0.2vh)"
    -
      transform = "translate(0.4vh, 0.4vh)"
    -
      transform = "translate(0.2vh, -0.4vh)"
  timing:
    delay = 0
    duration = "300ms"
    easing = "ease-in-out"
    iterations = "infinite"
    fill = "both"
    direction = "normal"
end

animation shiver with
  target = layer.self
  keyframes:
    -
      transform = "translate(0.2vh, 0.1vh)"
    -
      transform = "translate(-0.1vh, -0.2vh)"
    -
      transform = "translate(-0.3vh, 0vh)"
    -
      transform = "translate(0vh, 0.2vh)"
    -
      transform = "translate(0.1vh, -0.1vh)"
    -
      transform = "translate(-0.1vh, 0.2vh)"
    -
      transform = "translate(-0.3vh, 0.1vh)"
    -
      transform = "translate(0.2vh, 0.1vh)"
    -
      transform = "translate(-0.1vh, -0.1vh)"
    -
      transform = "translate(0.2vh, 0.2vh)"
    -
      transform = "translate(0.1vh, -0.2vh)"
  timing:
    delay = 0
    duration = "300ms"
    easing = "ease-in-out"
    iterations = 1
    fill = "none"
    direction = "normal"
end

animation shivering with
  target = layer.self
  keyframes:
    -
      transform = "translate(0.2vh, 0.1vh)"
    -
      transform = "translate(-0.1vh, -0.2vh)"
    -
      transform = "translate(-0.3vh, 0vh)"
    -
      transform = "translate(0vh, 0.2vh)"
    -
      transform = "translate(0.1vh, -0.1vh)"
    -
      transform = "translate(-0.1vh, 0.2vh)"
    -
      transform = "translate(-0.3vh, 0.1vh)"
    -
      transform = "translate(0.2vh, 0.1vh)"
    -
      transform = "translate(-0.1vh, -0.1vh)"
    -
      transform = "translate(0.2vh, 0.2vh)"
    -
      transform = "translate(0.1vh, -0.2vh)"
  timing:
    delay = 0
    duration = "300ms"
    easing = "ease-in-out"
    iterations = "infinite"
    fill = "none"
    direction = "normal"
end

animation waitout with
  target = layer.self
  keyframes:
    -
      opacity = "0"
  timing:
    delay = 0
    duration = "0.5s"
    easing = "step-end"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation waitin with
  target = layer.self
  keyframes:
    -
      opacity = "1"
  timing:
    delay = 0
    duration = "0.5s"
    easing = "step-end"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation fadeout with
  target = layer.self
  keyframes:
    -
      opacity = "0"
  timing:
    delay = 0
    duration = "0.5s"
    easing = "linear"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation fadein with
  target = layer.self
  keyframes:
    -
      opacity = "1"
  timing:
    delay = 0
    duration = "0.5s"
    easing = "linear"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation pulse with
  target = layer.self
  keyframes:
    -
      opacity = "0"
    -
      opacity = "1"
    -
      opacity = "0"
  timing:
    delay = 0
    duration = "1s"
    easing = "linear"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation blackout with
  target = layer.self
  keyframes:
    -
      background_color = "black"
      opacity = "0"
    -
      background_color = "black"
      opacity = "1"
  timing:
    delay = 0
    duration = "0.5s"
    easing = "linear"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation blackin with
  target = layer.self
  keyframes:
    -
      background_color = "black"
      opacity = "1"
    -
      background_color = "black"
      opacity = "0"
  timing:
    delay = 0
    duration = "0.5s"
    easing = "linear"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation blackpulse with
  target = layer.self
  keyframes:
    -
      background_color = "black"
      opacity = "0"
    -
      background_color = "black"
      opacity = "1"
    -
      background_color = "black"
      opacity = "0"
  timing:
    delay = 0
    duration = "1s"
    easing = "linear"
    iterations = 1
    fill = "both"
    direction = "normal"
end

animation whiteout with
  target = layer.self
  keyframes:
    -
      background_color = "white"
      opacity = "0"
    -
      background_color = "white"
      opacity = "1"
  timing:
    delay = 0
    duration = "0.5s"
