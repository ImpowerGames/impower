// The implicitly-imported builtins prelude: a `define` for every builtin
// type/instance. Compiled into every program so builtins populate both
// program.context (LSP) and the runtime __def tables (engine).
//
// This is the hand-maintained source of truth for builtins. Edit it directly —
// the compiler imports it as raw text via `builtins.sd?raw` (esbuild + Vite),
// so there's no generated wrapper to regenerate. `prelude.test.ts` compile-
// checks it.

define metadata with
  title = ""
  credit = ""
  author = ""
  source = ""
  notes = ""
  date = ""
  contact = ""
  revision = ""
  font = ""
  header = ""
  footer = ""
  watermark = ""
  tl = ""
  tc = ""
  tr = ""
  cc = ""
  bl = ""
  br = ""
end

define filter with
  includes = { "" }
  excludes = { "" }
end

define world with
  src = ""
end

define config with
end

define ui as config with
  styles_element_name = "styles"
  screens_element_name = "screens"
  breakpoints = { xs = 400, sm = 640, md = 768, lg = 1024, xl = 1280 }
end

define interpreter as config with
  directives = { title = "^", heading = "$", transitional = "%", action = "" }
  fallbacks = { layer = "portrait", channel = "sound" }
end

define image with
  ["$link"] = { audio = {}, synth = {}, character = {}, typewriter = {}, inflection = {}, prosody = {} }
  src = ""
  data = ""
end

define layered_image with
  assets = { image.none }
end

define filtered_image with
  image = image.none
  filters = { filter.none }
end

