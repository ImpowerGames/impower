  keyframes:
    -
      background_color = "white"
      opacity = "1"
    -
      background_color = "white"
      opacity = "0"
  timing:
    delay = 0
    duration = "0.5s"
    easing = "linear"
    iterations = 1
    fill = "both"
    direction = "normal"
