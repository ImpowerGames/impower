    duration = "1s"
    easing = "linear"
    iterations = 1
    fill = "both"
    direction = "normal"
end

define transition with
  on_hide = animation.hide
  on_show = animation.show
end

define fade as transition with
  on_hide = animation.fadeout
  on_show = animation.fadein
end

define screenfade as transition with
  on_hide = animation.waitout
  on_show = animation.waitin
  screen = animation.blackpulse
end

define screenflash as transition with
  on_hide = animation.waitout
  on_show = animation.waitin
  screen = animation.whitepulse
end

