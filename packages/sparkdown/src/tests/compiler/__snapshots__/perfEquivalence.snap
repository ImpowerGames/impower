    "context": {
      "animation": {
        "$default": {
          "$name": "$default",
          "$type": "animation",
          "keyframes": {},
          "target": {
            "$name": "self",
            "$type": "layer"
          },
          "timing": {
            "delay": 0,
            "direction": "normal",
            "duration": 0,
            "easing": "ease",
            "fill": "both",
            "iterations": 1
          }
        },
        "align_center": {
          "$name": "align_center",
          "$type": "animation",
          "keyframes": [
            {
              "translate": "calc(0.5 * (100cqw - 100%)) 0"
            }
          ],
          "target": {
            "$name": "instance",
            "$type": "layer"
          },
          "timing": {
            "delay": 0,
            "direction": "normal",
            "duration": 0,
            "easing": "ease-in-out",
            "fill": "both",
            "iterations": 1
          }
        },
