            "easing": "ease",
            "fill": "both",
            "iterations": 1
          }
        },
        "align_center": {
          "$name": "align_center",
          "$type": "animation",
          "keyframes": [
            {
              "translate": "calc(0.5 * (100cqw - 100%)) 0"
