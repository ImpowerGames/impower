          "$name": "music",
          "$type": "mixer",
          "gain": 1
        },
        "sound": {
          "$name": "sound",
          "$type": "mixer",
          "gain": 1
        },
        "typewriter": {
          "$name": "typewriter",
          "$type": "mixer",
          "gain": 1
        },
        "voice": {
          "$name": "voice",
          "$type": "mixer",
          "gain": 1
        }
      },
      "prosody": {
        "$default": {
          "$link": {
            "audio": {},
            "character": {},
            "image": {},
            "inflection": {},
            "synth": {},
            "typewriter": {}
          },
          "$name": "$default",
          "$type": "prosody",
          "anxious": "/(?:^|\\b)[.][.]([.]+)[ \"']*$/",
          "anxious_lilt": "/(?:^|\\b)([~]+)[.][.][.]+[ \"']*$/",
          "anxious_question": "/(?:^|\\b)[.][.][.]+([?]+)[ \"']*$/",
          "comma": "/(?:^|\\b)([,])[ \"']*$/",
          "exclamation": "/(?:^|\\b)([!?]*[!][!?]*)[ \"']*$/",
          "lilt": "/(?:^|\\b)([~]+)[ ]*$/",
          "lilt_exclamation": "/(?:^|\\b)[~]+([!]+)[ \"']*$/",
          "lilt_question": "/(?:^|\\b)[~]+([!?]*[?][!?]*)[ \"']*$/",
          "partial": "/(?:^|\\b)[-]([-]+)[ \"']*$/",
          "question": "/(?:^|\\b)([!?]*[?][!?]*)[ \"']*$/",
          "resolved_anxious_question": "/(?:^|\\b)(?:who|whose|what|when|where|why|which|how)\\b.*\\b[^\\t\\n\\r !?]+[.][.][.]+([!?]*[?][!?]*)[ \"']*$/",
          "resolved_question": "/(?:^|\\b)(?:who|whose|what|when|where|why|which|how)\\b.*\\b[^\\t\\n\\r !?]+([!?]*[?][!?]*)[ \"']*$/",
          "statement": "/(?:^|\\b)([.])[ \"']*$/"
        }
      },
      "screen": {
        "$default": {
          "$name": "$default",
          "$recursive": true,
          "$type": "screen"
        }
      },
      "script": {
        "__builtins__": {
          "$name": "__builtins__",
          "$type": "script",
          "ext": "sd",
          "languageId": "sparkdown",
          "name": "__builtins__",
          "type": "script",
          "uri": "file:///__builtins__.sd",
          "version": 0
        },
        "main": {
          "$name": "main",
          "$type": "script",
          "ext": "sd",
          "languageId": "sparkdown",
          "name": "main",
          "type": "script",
          "uri": "inmemory:///main.sd",
          "version": 1
        }
      },
      "shadow": {
        "$default": {
          "$name": "$default",
          "$type": "shadow",
          "layers": [
            {
              "blur": 3,
              "color": "black",
              "opacity": 0.3,
              "spread": 0,
              "x": 0,
              "y": 1
            },
            {
              "blur": 8,
              "color": "black",
              "opacity": 0.15,
              "spread": 3,
              "x": 0,
              "y": 4
            }
          ]
        },
        "lg": {
