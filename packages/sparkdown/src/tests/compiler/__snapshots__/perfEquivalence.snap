      "style": {
        "$default": {
          "$name": "$default",
          "$recursive": true,
          "$type": "style"
        },
        "action": {
          "$name": "action",
          "$type": "style",
          "align_self": "center",
          "display": "flex",
          "flex_direction": "column",
          "inset": "0",
          "justify_content": "center",
          "padding_left": "40px",
          "padding_right": "40px",
          "position": "absolute",
          "text_align": "center"
        },
        "backdrop": {
          "$name": "backdrop",
          "$type": "style",
          "background_position": "center",
          "background_size": "cover",
          "inset": "0",
          "position": "absolute"
        },
        "button": {
          "$name": "button",
          "$type": "style",
          "@hovered": {
            "background_color": "rgb(69 69 69)"
          },
          "align_items": "center",
          "background_color": "rgb(52 52 52)",
          "border": "1px solid rgb(95 95 95)",
          "border_radius": "8px",
          "color": "white",
          "cursor": "pointer",
          "display": "flex",
          "flex_direction": "row",
          "font_weight": "600",
          "justify_content": "center",
          "padding": "8px 20px",
          "text_align": "center",
          "transition": "background-color 0.15s linear"
        },
        "character_info": {
          "$name": "character_info",
          "$type": "style",
          "@screen_size(sm)": {
            "font_size": "1.5rem"
          },
          "align_items": "flex-end",
          "display": "flex",
          "flex_direction": "row",
          "font_size": "1.875rem",
          "gap": "8px",
          "justify_content": "center",
          "line_height": "1"
        },
        "character_name": {
          "$name": "character_name",
          "$type": "style",
          "font_weight": "600px",
          "padding_bottom": "8px"
        },
        "character_parenthetical": {
          "$name": "character_parenthetical",
