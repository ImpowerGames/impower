          "position": "absolute",
          "text_stroke": "1",
          "text_wrap": "wrap",
          "user_select": "none",
          "white_space": "pre-line"
        },
        "text": {
          "$name": "text",
          "$type": "style",
          ">> *": {
            "display": "inline"
          },
          "display": "block",
          "pointer_events": "auto",
          "text_wrap": "wrap",
          "user_select": "none",
          "white_space": "pre-line"
        },
        "text_letter": {
