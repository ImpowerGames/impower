            "fill": "both",
            "iterations": 1
          }
        },
        "blackin": {
          "$name": "blackin",
          "$type": "animation",
          "keyframes": [
            {
              "background_color": "black",
              "opacity": "1"
            },
            {
              "background_color": "black",
              "opacity": "0"
            }
          ],
          "target": {
            "$name": "self",
