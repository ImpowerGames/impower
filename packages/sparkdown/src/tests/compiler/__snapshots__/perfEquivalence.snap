          "font_weight": "400px",
          "padding_bottom": "8px"
        },
        "checkbox": {
          "$name": "checkbox",
          "$type": "style",
          "accent_color": "rgb(96 165 250)",
          "cursor": "pointer",
          "height": "20px",
          "width": "20px"
        },
        "choice": {
          "$name": "choice",
          "$type": "style",
          "@hovered": {
            "background_color": "black",
            "transition": "all 0.15s linear"
          },
          "align_items": "center",
          "background_color": "rgb(0 0 0 / 65%)",
          "border": "1px solid",
          "border_radius": "8px",
          "cursor": "pointer",
          "display": "flex",
          "flex_direction": "row",
          "justify_content": "center",
          "max_width": "800px",
          "padding": "8px",
          "text_align": "center",
          "width": "90%"
        },
        "choices": {
          "$name": "choices",
          "$type": "style",
          "@screen_size(sm)": {
            "margin_bottom": "120px"
          },
          "align_items": "center",
          "display": "flex",
          "flex": "1",
          "flex_direction": "column",
          "gap": "8px",
          "justify_content": "center",
          "margin_bottom": "100px",
          "position": "relative",
          "width": "100%"
        },
        "column": {
          "$name": "column",
          "$type": "style",
          "display": "flex",
          "flex_direction": "column"
        },
        "continue_indicator": {
          "$name": "continue_indicator",
          "$type": "style",
          "animation": "0.5s infinite bounce",
          "animation_play_state": "paused",
          "bottom": "16px",
          "font_size": "16px",
          "height": "16px",
          "line_height": "1",
          "opacity": "0",
          "position": "absolute",
          "right": "16px",
          "transition": "opacity 0.25s linear",
          "width": "16px"
        },
        "dialogue": {
          "$name": "dialogue",
          "$type": "style",
          "@screen_size(sm)": {
            "width": "80%"
          },
          "margin": "0 auto",
          "width": "68%"
        },
        "dropdown": {
          "$name": "dropdown",
          "$type": "style",
          "background_color": "rgb(37 37 37)",
          "border": "1px solid rgb(95 95 95)",
          "border_radius": "6px",
          "color": "white",
          "cursor": "pointer",
          "padding": "8px 12px"
        },
        "field": {
          "$name": "field",
          "$type": "style",
          "background_color": "rgb(37 37 37)",
          "border": "1px solid rgb(95 95 95)",
          "border_radius": "6px",
          "color": "white",
          "padding": "8px 12px"
        },
        "heading": {
          "$name": "heading",
          "$type": "style",
          "align_self": "center",
          "display": "flex",
          "flex_direction": "column",
          "font_weight": "bold",
          "inset": "0",
          "justify_content": "center",
          "padding_left": "40px",
          "padding_right": "40px",
          "position": "absolute",
          "text_align": "center"
        },
        "image": {
          "$name": "image",
          "$type": "style",
          "> *": {
            "background_position": "center",
            "background_repeat": "no-repeat",
            "background_size": "auto 100%",
            "inset": "0",
            "min_width": "100%",
            "position": "absolute",
            "translate": "calc(0.5 * (100cqw - 100%)) 0",
            "width": "fit-content",
            "will_change": "transform"
          },
          "container_name": "image",
          "container_type": "size",
          "display": "block",
          "inset": "0",
          "isolation": "isolate",
          "pointer_events": "auto",
          "position": "absolute",
          "will_change": "transform"
        },
        "link": {
          "$name": "link",
          "$type": "style",
          "color": "rgb(96 165 250)",
          "cursor": "pointer",
          "text_decoration": "underline"
        },
        "loading_bar": {
          "$name": "loading_bar",
          "$type": "style",
          "height": "4px",
          "position": "relative",
          "width": "100%",
          "z_index": "1000"
        },
        "loading_fill": {
          "$name": "loading_fill",
          "$type": "style",
          "background_color": "cyan50",
          "height": "100%",
          "transform": "scaleX(var(--loading_progress))",
          "transform_origin": "left",
          "width": "100%"
        },
        "main": {
          "$name": "main",
          "$type": "style",
          "@screen_size(sm)": {
            "font_size": "1.125rem"
          },
          "color": "white",
          "font_family": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto,\n    Helvetica, Arial, system-ui, sans-serif, \"Apple Color Emoji\",\n    \"Segoe UI Emoji\", \"Segoe UI Symbol\"",
          "font_size": "1.25rem",
          "line_height": "1.5"
        },
        "mask": {
          "$name": "mask",
          "$type": "style",
          "> *": {
            "inset": "0",
            "mask_position": "center",
            "mask_repeat": "no-repeat",
            "mask_size": "auto 100%",
            "mix_blend_mode": "plus-lighter",
            "position": "absolute",
            "will_change": "transform"
          },
          "display": "block",
          "inset": "0",
          "isolation": "isolate",
          "pointer_events": "auto",
          "position": "absolute",
          "will_change": "transform"
        },
        "object": {
          "$name": "object",
          "$type": "style",
          "height": "100%",
          "object_fit": "cover",
          "visibility": "hidden"
        },
        "option": {
          "$name": "option",
          "$type": "style",
          "background_color": "rgb(37 37 37)",
          "color": "white"
        },
        "overlay": {
          "$name": "overlay",
          "$type": "style",
          "inset": "0",
          "position": "absolute"
        },
        "portrait": {
          "$name": "portrait",
          "$type": "style",
          "> image >> *": {
            "mix_blend_mode": "plus-lighter"
          },
          "background_position": "center",
          "background_size": "auto 100%",
          "bottom": "0",
          "display": "flex",
          "flex_direction": "column",
          "left": "0",
          "position": "absolute",
          "right": "0",
          "top": "10%"
        },
        "row": {
          "$name": "row",
          "$type": "style",
          "display": "flex",
          "flex_direction": "row"
        },
        "screen": {
          "$name": "screen",
          "$type": "style",
          ">> *": {
            "pointer_events": "none"
          },
          "inset": "0",
          "pointer_events": "none",
          "position": "absolute"
        },
        "slider": {
          "$name": "slider",
          "$type": "style",
          "accent_color": "rgb(96 165 250)",
          "cursor": "pointer",
          "width": "200px"
        },
        "stack": {
          "$name": "stack",
          "$type": "style",
          "> *": {
            "inset": "0",
            "position": "absolute"
          }
        },
        "stage": {
          "$name": "stage",
          "$type": "style",
          "display": "flex",
          "flex_direction": "column",
          "inset": "0",
          "position": "absolute"
        },
        "stroke": {
          "$name": "stroke",
