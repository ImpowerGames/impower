          },
          "$name": "$default",
          "$type": "prosody",
          "anxious": "/(?:^|\\b)[.][.]([.]+)[ \"']*$/",
          "anxious_lilt": "/(?:^|\\b)([~]+)[.][.][.]+[ \"']*$/",
          "anxious_question": "/(?:^|\\b)[.][.][.]+([?]+)[ \"']*$/",
          "comma": "/(?:^|\\b)([,])[ \"']*$/",
          "exclamation": "/(?:^|\\b)([!?]*[!][!?]*)[ \"']*$/",
          "lilt": "/(?:^|\\b)([~]+)[ ]*$/",
          "lilt_exclamation": "/(?:^|\\b)[~]+([!]+)[ \"']*$/",
          "lilt_question": "/(?:^|\\b)[~]+([!?]*[?][!?]*)[ \"']*$/",
          "partial": "/(?:^|\\b)[-]([-]+)[ \"']*$/",
          "question": "/(?:^|\\b)([!?]*[?][!?]*)[ \"']*$/",
          "resolved_anxious_question": "/(?:^|\\b)(?:who|whose|what|when|where|why|which|how)\\b.*\\b[^\\t\\n\\r !?]+[.][.][.]+([!?]*[?][!?]*)[ \"']*$/",
          "resolved_question": "/(?:^|\\b)(?:who|whose|what|when|where|why|which|how)\\b.*\\b[^\\t\\n\\r !?]+([!?]*[?][!?]*)[ \"']*$/",
          "statement": "/(?:^|\\b)([.])[ \"']*$/"
        }
