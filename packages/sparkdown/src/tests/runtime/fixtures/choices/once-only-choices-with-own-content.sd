store times = 3
-> home

scene home
  & times = times - 1
  if times >= 0 then
    -> eat
  end
  I've finished eating now.
  fin

end
scene eat
  This is the {chain | "first" | "second" | "third" end} time.
  choose
    * Eat ice-cream[]
    * Drink coke[]
    * Munch cookies[]
  then
    -> home
  end
end
