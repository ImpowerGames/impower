Default line 1
Default line 2

scene red
  Hello I'm red
  <- thread1("red")
  <- thread2("red")
  done

end
scene blue
  Hello I'm blue
  <- thread1("blue")
  <- thread2("blue")
  done

end
scene thread1(name)
  choose
    + Thread 1 {name} choice
  then
    -> thread1Choice(name)
  end

end
scene thread2(name)
  choose
    + Thread 2 {name} choice
  then
    -> thread2Choice(name)
  end

end
scene thread1Choice(name)
  After thread 1 choice ({name})
  fin

end
scene thread2Choice(name)
  After thread 2 choice ({name})
  fin
end
