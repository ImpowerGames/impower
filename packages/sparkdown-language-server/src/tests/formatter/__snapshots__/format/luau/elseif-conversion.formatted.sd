function plain()
  if a then
    return 1
  elseif b then
    return 2
  end
end

function nested()
  if a then
    return 1
  elseif b then
    return 2
  elseif c then
    return 3
  end
end

function keep_as_is()
  if a then
    return 1
  else
    x = 1
    if b then
      return 2
    end
  end
end
