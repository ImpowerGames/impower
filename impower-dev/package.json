{
  "name": "impower-dev",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "kill": "kill-port 8080",
    "build:dev:workers:sparkdown-language-server": "cd ../packages/sparkdown-language-server && node ./esbuild.js --outdir=../../impower-dev/out/public && cd ../../impower-dev",
    "build:prod:workers:sparkdown-language-server": "cd ../packages/sparkdown-language-server && node ./esbuild.js --outdir=../../impower-dev/out/public --production && cd ../../impower-dev",
    "build:dev:workers:sparkdown-screenplay-pdf": "cd ../packages/sparkdown-screenplay-pdf && node ./esbuild.js --outdir=../../impower-dev/out/public && cd ../../impower-dev",
    "build:prod:workers:sparkdown-screenplay-pdf": "cd ../packages/sparkdown-screenplay-pdf && node ./esbuild.js --outdir=../../impower-dev/out/public --production && cd ../../impower-dev",
    "build:dev:workers:opfs-workspace": "cd ../packages/opfs-workspace && node ./esbuild.js --outdir=../../impower-dev/out/public && cd ../../impower-dev",
    "build:prod:workers:opfs-workspace": "cd ../packages/opfs-workspace && node ./esbuild.js --outdir=../../impower-dev/out/public --production && cd ../../impower-dev",
    "build:dev:workers": "npm-run-all -p build:dev:workers:*",
    "build:prod:workers": "npm-run-all -p build:prod:workers:*",
    "build:impower-ui": "cd ../packages/impower-ui && npm run build && cd ../../impower-dev",
    "dev": "tsx ./build.ts --watch",
    "preprod": "npm run build:impower-ui",
    "prod": "tsx ./build.ts --production",
    "prebuild": "npm run build:impower-ui",
    "build": "tsx ./build.ts --production --minify",
    "start": "node ./out/api/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/middie": "^9.3.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/static": "^9.0.0",
    "@impower/impower-ui": "file:../packages/impower-ui",
    "@impower/opfs-workspace": "file:../packages/opfs-workspace",
    "@impower/spark-editor-protocol": "file:../packages/spark-editor-protocol",
    "@impower/spark-engine": "file:../packages/spark-engine",
    "@impower/sparkdown": "file:../packages/sparkdown",
    "@impower/sparkdown-document-views": "file:../packages/sparkdown-document-views",
    "@impower/sparkdown-language-server": "file:../packages/sparkdown-language-server",
    "@impower/sparkdown-screenplay-pdf": "file:../packages/sparkdown-screenplay-pdf",
    "@preact/signals": "^2.9.0",
    "@tanstack/react-virtual": "^3.13.25",
    "dotenv": "^16.3.1",
    "fastify": "^5.8.4",
    "googleapis": "^159.0.0",
    "pino": "^8.14.1",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@adobe/css-tools": "^4.4.4",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.2.4",
    "@types/browser-resolve": "^2.0.4",
    "@types/gapi": "^0.0.47",
    "@types/gapi.client.drive-v3": "^0.0.5",
    "@types/google.accounts": "^0.0.18",
    "@types/google.picker": "^0.0.51",
    "@types/node": "^20.3.2",
    "@types/ws": "^8.5.5",
    "chokidar": "^3.5.3",
    "kill-port": "^2.0.1",
    "magic-string": "^0.30.21",
    "mkcert": "^3.0.0",
    "node-stdlib-browser": "^1.2.0",
    "npm-run-all": "^4.1.5",
    "parse5": "^7.1.2",
    "pino-pretty": "^10.0.0",
    "preact-render-to-string": "^6.5.0",
    "tiny-glob": "^0.2.9",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "@codemirror/autocomplete": "^6.19.0",
    "@codemirror/collab": "^6.1.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.11.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@impower/codemirror-vscode-lsp-client": "file:../packages/codemirror-vscode-lsp-client",
    "@impower/jsonrpc": "file:../packages/jsonrpc",
    "@lezer/common": "^1.2.3",
    "@lezer/highlight": "^1.2.1",
    "marked": "^17.0.4",
    "preact": "^10.29.1",
    "preact-custom-element": "^4.6.0",
    "style-mod": "^4.1.3",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
