{
  "comments": {
    "lineComment": "--",
    "blockComment": [
      "--[[",
      "]]"
    ]
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "colorizedBracketPairs": [],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "`",
      "close": "`"
    },
    {
      "open": "~~",
      "close": "~~"
    },
    {
      "open": "::",
      "close": "::"
    },
    {
      "open": "--[[",
      "close": "]]"
    },
    {
      "open": "--[=[",
      "close": "]=]"
    },
    {
      "open": "--[==[",
      "close": "]==]"
    }
  ],
  "autoCloseBefore": ";:.,=}])>` \t\n\r",
  "surroundingPairs": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "<",
      ">"
    ],
    [
      "\"",
      "\""
    ],
    [
      "`",
      "`"
    ],
    [
      "*",
      "*"
    ],
    [
      "_",
      "_"
    ],
    [
      "~",
      "~"
    ],
    [
      ":",
      ":"
    ],
    [
      "^",
      "^"
    ],
    [
      "--[[",
      "]]"
    ]
  ],
  "wordChars": "_'",
  "wordPattern": {
    "pattern": "(\\p{L}|\\p{N}|\\p{Mn})(((\\p{L}|\\p{N}|\\p{Mn})|[_]|['])?(\\p{L}|\\p{N}|\\p{Mn}))*",
    "flags": "u"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*--\\[(=*)\\[(?!.*\\]\\1\\]).*$",
      "afterText": "\\]=*\\]",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "^\\s*--\\[=*\\[(?!.*\\]=*\\]).*$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "\\bdefine\\s*$",
      "afterText": "^\\s*end\\b",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "\\bfunction\\b[^()]*\\([^()]*\\)[^()]*$",
      "afterText": "^\\s*end\\b",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "\\bthen\\s*$",
      "afterText": "^\\s*(end|elseif|else)\\b",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "\\bdo\\s*$",
      "afterText": "^\\s*end\\b",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "\\belse\\s*$",
      "afterText": "^\\s*end\\b",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "\\brepeat\\s*$",
      "afterText": "^\\s*until\\b",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "^\\s*---(?!-)\\s*\\S.*$",
      "action": {
        "indent": "none",
        "appendText": "--- "
      }
    },
    {
      "beforeText": "^\\s*[-]\\s+[{]\\s*$",
      "afterText": "\\s*[}]",
      "action": {
        "indent": "indentOutdent",
        "appendText": "\t- "
      }
    },
    {
      "beforeText": "^.*[{]\\s*$",
      "afterText": "\\s*[}]",
      "action": {
        "indent": "indentOutdent",
        "appendText": "- "
      }
    },
    {
      "beforeText": "^\\s*[-]\\s+.*?(?<![:])\\s*$",
      "previousLineText": "(?=^.*\\s*[{].*)(?=(?!\\s*[}]))|(?=^.*\\s*[-]\\s+.*?(?<![:])\\s*$)",
      "action": {
        "indent": "none",
        "appendText": "- "
      }
    },
    {
      "beforeText": "^.*[{][^}]*$",
      "afterText": "\\s*[}]",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "^\\s*([+]\\s+)+.*?$",
      "action": {
        "indent": "none"
      }
    },
    {
      "beforeText": "^\\s*([*]\\s+)+.*?$",
      "action": {
        "indent": "none"
      }
    },
    {
      "beforeText": "^\\s*([-]\\s+)+.*?$",
      "action": {
        "indent": "none"
      }
    },
    {
      "beforeText": "^(.*?)([-][>])(.*?)([-][>])(.*?)$",
      "action": {
        "indent": "none"
      }
    },
    {
      "beforeText": "^(.*?)([-][>])(.*?)$",
      "action": {
        "indent": "outdent"
      }
    },
    {
      "beforeText": "\\[\\s*$",
      "afterText": "^\\s*\\].*$",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "\\[\\s*$",
      "afterText": "^(?!\\s*\\])",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "\\(\\s*$",
      "afterText": "^\\s*\\).*$",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "\\(\\s*$",
      "afterText": "^(?!\\s*\\))",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*(?:[^:\"]|[\"](?:[^\"\\\\]|\\\\.)*[\"])+:\\s*$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*(?:[-])\\s*$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*(?:[-])\\s+.*(?:\\s[=]\\s).*$",
      "action": {
        "indent": "indent"
      }
    }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^((?!--).)*((\\b(else|then|do|repeat|define|scene|branch)\\b\\s*(--.*)?$)|(\\bfunction\\b(?:(?!\\bend\\b).)*$)|([\\{\\(\\[]\\s*(--.*)?$))",
    "decreaseIndentPattern": "^\\s*((\\b(elseif|else|end|until)\\b)|\\}|\\)|\\])",
    "indentNextLinePattern": "^((?!--).)*(?<![=<>!~])=\\s*(--.*)?$",
    "unIndentedLinePattern": "^#\\!"
  },
  "folding": {
    "offSide": false,
    "markers": {
      "start": "^\\s*--\\s*#?region\\b",
      "end": "^\\s*--\\s*#?endregion\\b"
    }
  }
}